{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "PORT=3000 BASE_PATH=/ pnpm --filter ./artifacts/country-draft run dev",
    "start": "PORT=3000 BASE_PATH=/ pnpm --filter ./artifacts/country-draft run serve",
    "test": "pnpm -r --if-present run test"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.61.1",
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "firebase": "^12.14.0"
  }
}
